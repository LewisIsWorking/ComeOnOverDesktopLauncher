<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.ExternalCard"
             x:DataType="vm:ExternalInstanceViewModel">

    <Design.DataContext>
        <vm:ExternalInstanceViewModel/>
    </Design.DataContext>

    <!-- External Claude card: visually de-emphasised vs SlotCard to
         communicate "I didn't launch this, you did". Grayer border,
         thumbnail at reduced opacity, smaller "External" header badge.
         Same 256px width so both collections tile together consistently. -->
    <Border Width="256"
            Margin="4"
            Padding="8"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="4"
            Background="#151515">
        <StackPanel Spacing="8">

            <!-- Thumbnail (muted) -->
            <Border Height="150"
                    Background="#0A0A0A"
                    BorderBrush="#222"
                    BorderThickness="1"
                    CornerRadius="3"
                    ToolTip.Tip="Live preview of this externally-launched Claude window. Refreshes on every poll tick.">
                <Image Source="{Binding Thumbnail}"
                       Stretch="Uniform"
                       Opacity="0.85"/>
            </Border>

            <!-- External badge + PID -->
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Background="#2A2A2A" CornerRadius="3" Padding="6,2"
                        VerticalAlignment="Center"
                        ToolTip.Tip="This Claude window was not launched by CoODL. It's using the default profile or a user-data-dir outside the ClaudeSlotN convention.">
                    <TextBlock Text="External"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#999"/>
                </Border>
                <TextBlock Text="{Binding Pid, StringFormat='PID {0}'}"
                           FontSize="10" Foreground="Gray"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Command line (trimmed, tooltip has full) -->
            <TextBlock Text="{Binding CommandLineDisplay}"
                       FontSize="11"
                       Foreground="#B0B0B0"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding CommandLine}"/>

            <!-- Stats row: CPU, RAM, Uptime, Close -->
            <Grid ColumnDefinitions="*,*,*,Auto">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="CPU" FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0}%'}"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="RAM" FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Up" FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding UptimeDisplay}"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="3"
                        Content="X"
                        Command="{Binding CloseCommand}"
                        Foreground="#EF9A9A"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Padding="8,2"
                        ToolTip.Tip="Close this external Claude (asks for confirmation first)"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
