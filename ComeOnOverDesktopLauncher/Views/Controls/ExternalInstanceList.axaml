<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             xmlns:controls="using:ComeOnOverDesktopLauncher.Views.Controls"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.ExternalInstanceList"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- v1.9.1: migrated from row template to a WrapPanel grid of
         ExternalCard controls. ExternalCard is de-emphasised vs
         SlotCard (grayer border, muted thumbnail) to communicate
         "I didn't launch this". -->
    <Border IsVisible="{Binding ExternalInstances.HasExternalInstances}"
            BorderThickness="0,1,0,0" BorderBrush="#444"
            Margin="0,10,0,0" Padding="0,10,0,0">
        <StackPanel Spacing="8">

            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="External Claude instances"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           ToolTip.Tip="Claude windows running on this system that were NOT started by the launcher (e.g. default-profile Claude launched from the Start menu)."/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ExternalInstances.TotalRamMb, StringFormat='{}{0} MB'}"
                           FontSize="10" Foreground="Gray"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding ExternalInstances.TotalCpuPercent, StringFormat='{}{0}%'}"
                           FontSize="10" Foreground="Gray"
                           VerticalAlignment="Center"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding ExternalInstances.Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ExternalInstanceViewModel">
                        <controls:ExternalCard/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
