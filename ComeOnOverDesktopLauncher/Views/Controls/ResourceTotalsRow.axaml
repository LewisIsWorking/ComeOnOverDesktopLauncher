<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.ResourceTotalsRow"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Border BorderThickness="1" CornerRadius="4" Padding="10,8">
        <Grid ColumnDefinitions="*,*,*,*,Auto,Auto,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Running" FontSize="10" Foreground="Gray"/>
                <TextBlock Text="{Binding Resources.RunningInstanceCount}"
                           FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Total RAM" FontSize="10" Foreground="Gray"/>
                <TextBlock Text="{Binding Resources.TotalRamMb, StringFormat='{}{0} MB'}"
                           FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Total CPU" FontSize="10" Foreground="Gray"/>
                <TextBlock Text="{Binding Resources.TotalCpuPercent, StringFormat='{}{0}%'}"
                           FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBlock Text="Disk" FontSize="10" Foreground="Gray"/>
                <TextBlock Text="Scanning..."
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="Gray"
                           IsVisible="{Binding Resources.IsDiskScanning}"
                           ToolTip.Tip="Scanning all Claude data directories... this can take a few minutes on large installs."/>
                <TextBlock Text="{Binding Resources.TotalDiskGb, StringFormat='{}{0} GB'}"
                           FontSize="16" FontWeight="SemiBold"
                           IsVisible="{Binding !Resources.IsDiskScanning}"
                           ToolTip.Tip="Total on-disk size of all ClaudeSlot* and ClaudeInstance* directories. Refreshes at startup and on manual refresh (? button). Large installs may take several minutes to scan."/>
            </StackPanel>            <Button Grid.Column="4" Content="?"
                    Command="{Binding Resources.ManualRefreshCommand}"
                    Padding="8,4" FontSize="13"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Refresh resource stats"/>
            <Button Grid.Column="5" Content="Copy"
                    Name="CopyButton"
                    Padding="8,4" FontSize="11"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Copy a screenshot of the launcher window to the clipboard"/>
            <Button Grid.Column="6" Content="Logs"
                    Command="{Binding OpenLogsFolderCommand}"
                    Padding="8,4" FontSize="11"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Open the diagnostic log folder in Explorer"/>
        </Grid>
    </Border>
</UserControl>
