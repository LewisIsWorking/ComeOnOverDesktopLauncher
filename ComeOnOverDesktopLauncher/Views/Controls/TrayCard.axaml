<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.TrayCard"
             x:DataType="vm:ClaudeInstanceViewModel">

    <Design.DataContext>
        <vm:ClaudeInstanceViewModel/>
    </Design.DataContext>

    <!-- Tray-resident slot card. Structurally a SlotCard but with:
         - A "Hidden" overlay badge on top of the thumbnail (so the user
           knows the capture is the last-known frame, not live)
         - Read-only italic nickname (you can't usefully edit the name
           of a slot you can't see)
         - A "Quit" button instead of "X" (force-kill, no confirm
           dialog - the window is already gone) -->
    <Border Width="256"
            Margin="4"
            Padding="8"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="4"
            Background="#171717"
            Opacity="0.85">
        <StackPanel Spacing="8">

            <!-- Thumbnail with "Hidden" overlay. Tap opens the
                 lightbox preview - works on the last-known frame
                 too, which is the whole point of keeping it around. -->
            <Grid>
                <Border Height="150"
                        Background="#0D0D0D"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="3"
                        Cursor="Hand"
                        PointerPressed="OnThumbnailPressed"
                        ToolTip.Tip="Click to enlarge the last-known preview. Not live - the window has been closed to tray. Reopen from the system tray to capture fresh.">
                    <Image Source="{Binding Thumbnail}"
                           Stretch="Uniform"
                           Opacity="0.6"
                           IsHitTestVisible="False"/>
                </Border>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,6,6,0"
                        Background="#2A2A2A"
                        BorderBrush="#555"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="5,2"
                        IsHitTestVisible="False">
                    <TextBlock Text="Hidden"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#CCC"/>
                </Border>
            </Grid>

            <!-- Slot pill row (no login pill - only relevant for visible slots) -->
            <Border Background="#3A3A3A" CornerRadius="3" Padding="6,2"
                    HorizontalAlignment="Left"
                    ToolTip.Tip="This is the ClaudeSlotN data directory the instance is using.">
                <TextBlock Text="{Binding InstanceNumber, StringFormat='Slot {0}'}"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="#DADADA"/>
            </Border>

            <!-- Read-only nickname -->
            <TextBlock Text="{Binding SlotName}"
                       FontSize="12"
                       FontStyle="Italic"
                       Foreground="#A0A0A0"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Stats row: CPU, RAM, Uptime, Show, Quit -->
            <Grid ColumnDefinitions="*,*,*,Auto,Auto">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="CPU" FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0}%'}"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="RAM" FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Up" FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding UptimeDisplay}"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="3"
                        Content="Show"
                        Command="{Binding ShowCommand}"
                        Foreground="#80CBC4"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#2A4A48"
                        FontSize="10"
                        Padding="8,2"
                        ToolTip.Tip="Restore this Claude window to the foreground. Reverses the Hide action - the slot will move back to the main list on the next scanner poll."/>
                <Button Grid.Column="4"
                        Content="Quit"
                        Command="{Binding KillCommand}"
                        Foreground="#EF9A9A"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#553030"
                        FontSize="10"
                        Padding="8,2"
                        ToolTip.Tip="Force-quit this tray-resident Claude process."/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
