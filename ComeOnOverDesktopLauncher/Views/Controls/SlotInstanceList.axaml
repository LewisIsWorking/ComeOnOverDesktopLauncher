<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.SlotInstanceList"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ItemsControl ItemsSource="{Binding SlotInstances.Items}"
                  IsVisible="{Binding HasRunningInstances}">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ClaudeInstanceViewModel">
                <Border BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,*,*,Auto,Auto,Auto">

                        <!-- Slot pill + login status + nickname -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Background="#3A3A3A" CornerRadius="3" Padding="6,2"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="This is the ClaudeSlotN data directory the instance is using.">
                                <TextBlock Text="{Binding InstanceNumber, StringFormat='Slot {0}'}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="#DADADA"/>
                            </Border>
                            <Border CornerRadius="3" Padding="5,2"
                                    ToolTip.Tip="{Binding LoginStatusTooltip}">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding LoginStatusBackground}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding LoginStatusText}"
                                           FontSize="9"
                                           FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding LoginStatusForeground}"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <TextBox Text="{Binding SlotName}"
                                     FontSize="12" FontWeight="SemiBold"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0,0,8,2"
                                     PlaceholderText="Name this slot..."
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- CPU -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="CPU" FontSize="9" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0}%'}"
                                       FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- RAM -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="RAM" FontSize="9" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}"
                                       FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Uptime -->
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="Up" FontSize="9" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding UptimeDisplay}"
                                       FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Kill button -->
                        <Button Grid.Column="4"
                                Content="X"
                                Command="{Binding KillCommand}"
                                Foreground="#EF9A9A"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Padding="8,4"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                ToolTip.Tip="Close this Claude instance"/>

                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
