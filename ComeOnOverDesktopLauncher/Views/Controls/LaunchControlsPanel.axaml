<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.LaunchControlsPanel"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="14">

        <!-- Launch controls -->
        <StackPanel Spacing="8" IsVisible="{Binding IsClaudeInstalled}">
            <TextBlock Text="Additional instances to open:" FontSize="13"/>
            <NumericUpDown Value="{Binding SlotCount}"
                           Minimum="1" Maximum="100"
                           FormatString="0"
                           Width="120"
                           HorizontalAlignment="Left"/>
            <Button Content="Launch Claude"
                    Command="{Binding LaunchInstancesCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
        </StackPanel>

        <!-- Claude not found warning -->
        <StackPanel IsVisible="{Binding !IsClaudeInstalled}" Spacing="4">
            <TextBlock Text="&#x26A0; Claude Desktop is not installed."
                       Foreground="OrangeRed" FontSize="13"/>
            <TextBlock Text="Download Claude Desktop from claude.ai/download to use this launcher."
                       Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Settings row -->
        <StackPanel Orientation="Horizontal" Spacing="16">
            <CheckBox Content="Launch on startup"
                      IsChecked="{Binding LaunchOnStartup}"
                      FontSize="12"
                      VerticalAlignment="Center"/>
            <CheckBox Content="Auto-update"
                      IsChecked="{Binding Update.AutoCheckEnabled}"
                      FontSize="12"
                      VerticalAlignment="Center"
                      ToolTip.Tip="When enabled, the launcher periodically checks GitHub for new releases and silently downloads any update in the background. You'll see a 'Restart to install' prompt when an update is ready - the restart always happens on your schedule, never silently. Disable this if you prefer to manage updates manually by downloading Setup.exe from the GitHub releases page."/>
            <CheckBox Content="Show thumbnails"
                      IsChecked="{Binding ThumbnailsEnabled}"
                      FontSize="12"
                      VerticalAlignment="Center"
                      ToolTip.Tip="Captures a live snapshot of each slot's Claude window every refresh interval and shows it alongside the slot stats. Toggle off if you want a minimal launcher or have privacy concerns. Thumbnails are kept in memory only - nothing is written to disk."/>
            <CheckBox Content="Usage on left"
                      IsChecked="{Binding UsagePanelOnLeft}"
                      FontSize="12"
                      VerticalAlignment="Center"
                      ToolTip.Tip="When checked, the Claude usage dashboard moves to the left side of the window. Right-click the divider bar to toggle this too."/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Refresh interval:" FontSize="12" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding Resources.IntervalSeconds}"
                               Minimum="1" Maximum="60"
                               FormatString="0"
                               Width="130"
                               VerticalAlignment="Center"/>
                <TextBlock Text="s" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="[i]"
                           FontSize="11"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Cursor="Help"
                           ToolTip.Tip="How often the CPU, RAM and uptime stats refresh for each running Claude instance. Lower = more accurate but uses slightly more CPU. Recommended: 5s"/>
            </StackPanel>
        </StackPanel>

        <!-- Update banner: state-aware display driven by UpdateOrchestrator.
             Three mutually-exclusive sub-banners for Downloading,
             ReadyToInstall, Failed states. Each binds IsVisible to a
             computed VM bool (IsUpdateDownloading etc.) so the XAML
             stays flat rather than nesting Converter logic. Matches
             v1.10.0 UX spec: silent download, prompt to restart. -->
        <StackPanel Spacing="4">
            <!-- Downloading: blue banner + progress bar -->
            <Border Background="#1A2196F3" CornerRadius="4" Padding="10,6"
                    IsVisible="{Binding Update.IsDownloading}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Update.DownloadingBannerText}"
                               Foreground="#64B5F6" FontSize="11"/>
                    <ProgressBar Value="{Binding Update.DownloadProgress}"
                                 Minimum="0" Maximum="100"
                                 Height="4"
                                 Foreground="#2196F3"
                                 Background="#0F2196F3"/>
                </StackPanel>
            </Border>

            <!-- ReadyToInstall: green banner + restart button + release notes link -->
            <Border Background="#1A4CAF25" CornerRadius="4" Padding="10,6"
                    IsVisible="{Binding Update.IsReadyToInstall}">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Update.ReadyBannerText}"
                               Foreground="#4CAF50" FontSize="11"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Content="What's new"
                            Command="{Binding Update.OpenReleaseNotesCommand}"
                            FontSize="11"
                            Padding="8,2"
                            Margin="8,0,4,0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Open the release notes on GitHub to see what changed in this version."/>
                    <Button Grid.Column="2"
                            Content="Restart to install"
                            Command="{Binding Update.RestartCommand}"
                            FontSize="11"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Exits the launcher, applies the downloaded update, and restarts automatically. Close any important Claude conversations first - your slots will stay open (they're separate processes) but the launcher window will briefly disappear."/>
                </Grid>
            </Border>

            <!-- Failed: amber banner + retry button -->
            <Border Background="#1AFFA726" CornerRadius="4" Padding="10,6"
                    IsVisible="{Binding Update.IsFailed}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Update check failed. Will retry automatically later."
                               Foreground="#FFA726" FontSize="11"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Content="Retry now"
                            Command="{Binding Update.RetryCommand}"
                            FontSize="11"
                            Padding="8,2"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ApplyFailed: red banner + download installer link.
                 Surfaces the v1.10.4+ detection of Velopack silently
                 reverting an apply failure. See IUpdateApplyFailureDetector. -->
            <Border Background="#1AE57373" CornerRadius="4" Padding="10,6"
                    IsVisible="{Binding Update.IsApplyFailed}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Update.ApplyFailedBannerText}"
                               Foreground="#E57373" FontSize="11"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Content="Download installer"
                            Command="{Binding Update.DownloadInstallerCommand}"
                            FontSize="11"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Opens the Setup.exe download in your browser. Running Setup.exe fresh usually works even when the in-app Restart flow can't (different file-locking characteristics). Alternatively, reboot your machine first and try Restart again."/>
                </Grid>
            </Border>
        </StackPanel>

    </StackPanel>
</UserControl>
