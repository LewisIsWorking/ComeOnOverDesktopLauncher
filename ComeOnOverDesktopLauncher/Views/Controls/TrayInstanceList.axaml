<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
             x:Class="ComeOnOverDesktopLauncher.Views.Controls.TrayInstanceList"
             x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Border IsVisible="{Binding SlotInstances.HasTrayItems}"
            BorderThickness="0,1,0,0" BorderBrush="#444"
            Margin="0,10,0,0" Padding="0,10,0,0">
        <StackPanel Spacing="8">

            <TextBlock Text="Hidden / tray"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="Gray"
                       ToolTip.Tip="Launcher-managed Claude slots that have been closed to the system tray. The process is still running (and counts toward Total RAM) but the window is not visible. Use the tray icon menu or reopen the slot from the launcher to bring it back."/>

            <ItemsControl ItemsSource="{Binding SlotInstances.TrayItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ClaudeInstanceViewModel">
                        <Border BorderThickness="0,0,0,1" BorderBrush="#2A2A2A" Padding="0,6">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">

                                <!-- Slot pill -->
                                <Border Grid.Column="0" Background="#3A3A3A" CornerRadius="3" Padding="6,2"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        ToolTip.Tip="This is the ClaudeSlotN data directory the instance is using.">
                                    <TextBlock Text="{Binding InstanceNumber, StringFormat='Slot {0}'}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="#DADADA"/>
                                </Border>

                                <!-- Nickname (read-only; can't edit what you can't see) -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SlotName}"
                                           FontSize="11"
                                           Foreground="#A0A0A0"
                                           FontStyle="Italic"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>

                                <!-- CPU -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="6,0">
                                    <TextBlock Text="CPU" FontSize="9" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0}%'}"
                                               FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- RAM -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center" Margin="6,0">
                                    <TextBlock Text="RAM" FontSize="9" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}"
                                               FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Uptime -->
                                <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="6,0">
                                    <TextBlock Text="Up" FontSize="9" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding UptimeDisplay}"
                                               FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Quit button (force-kill, no confirm dialog - user has
                                     already close-to-tray'd so no unsaved window to protect) -->
                                <Button Grid.Column="5"
                                        Content="Quit"
                                        Command="{Binding KillCommand}"
                                        Foreground="#EF9A9A"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="#553030"
                                        FontSize="10"
                                        Padding="8,3"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Force-quit this tray-resident Claude process."/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
