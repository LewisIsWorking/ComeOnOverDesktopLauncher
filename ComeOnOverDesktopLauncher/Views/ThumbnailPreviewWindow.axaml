<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ComeOnOverDesktopLauncher.Views.ThumbnailPreviewWindow"
        Width="900" Height="600"
        MinWidth="320" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A0A"
        Title="Preview">

    <!-- Click anywhere (outside the image) to close. The grid covers
         the whole window and forwards clicks to code-behind, which
         calls Close(). We keep the close-on-click behaviour to make
         the preview feel lightweight (like a lightbox) rather than
         like a persistent second window. Users can also Esc-close
         via the shortcut handled in code-behind. -->
    <Grid x:Name="Root" Focusable="True">
        <Image x:Name="PreviewImage"
               Stretch="Uniform"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Margin="16"/>
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Background="#1A1A1A"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="3"
                Padding="8,4"
                Margin="0,16,16,0"
                IsHitTestVisible="False">
            <TextBlock Text="Click anywhere or press Esc to close"
                       FontSize="10"
                       Foreground="#999"/>
        </Border>
    </Grid>
</Window>
