<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
        x:Class="ComeOnOverDesktopLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ComeOnOver Desktop Launcher"
        Width="420" Height="480"
        MinWidth="340" MinHeight="360"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="14">

            <TextBlock Text="ComeOnOver Desktop Launcher"
                       FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <!-- Launch controls -->
            <StackPanel Spacing="8" IsVisible="{Binding IsClaudeInstalled}">
                <TextBlock Text="Claude instances to open:" FontSize="13"/>
                <NumericUpDown Value="{Binding SlotCount}"
                               Minimum="1" Maximum="10"
                               FormatString="0"
                               Width="120"
                               HorizontalAlignment="Left"/>
                <Button Content="Launch Claude"
                        Command="{Binding LaunchInstancesCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="&#x26A0; Claude Desktop is not installed."
                       IsVisible="{Binding !IsClaudeInstalled}"
                       Foreground="OrangeRed" FontSize="13"/>

            <Button Content="Open ComeOnOver"
                    Command="{Binding LaunchComeOnOverCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>

            <!-- Combined resource totals -->
            <Border BorderThickness="1" CornerRadius="4" Padding="10,8">
                <Grid ColumnDefinitions="*,*,*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Running" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding RunningInstanceCount}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Total RAM" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalRamMb, StringFormat='{}{0} MB'}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Total CPU" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalCpuPercent, StringFormat='{}{0}%'}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Grid.Column="3" Content="↻"
                            Command="{Binding RefreshResourcesCommand}"
                            Padding="8,4" FontSize="13"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Per-instance resource list -->
            <ItemsControl ItemsSource="{Binding Instances}"
                          IsVisible="{Binding HasRunningInstances}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ClaudeInstanceViewModel">
                        <Border BorderThickness="0,0,0,1" Padding="0,6">
                            <Grid ColumnDefinitions="80,*,*,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding InstanceNumber, StringFormat='Instance {0}'}"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="CPU" FontSize="9" Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0}%'}"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="RAM" FontSize="9" Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="Up" FontSize="9" Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding UptimeDisplay}"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="Gray" FontSize="11"
                       HorizontalAlignment="Center"/>

        </StackPanel>
    </ScrollViewer>
</Window>
