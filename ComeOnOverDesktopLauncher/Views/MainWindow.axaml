<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
        x:Class="ComeOnOverDesktopLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ComeOnOver Desktop Launcher"
        Width="440" Height="520"
        MinWidth="360" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="14">

            <TextBlock Text="ComeOnOver Desktop Launcher"
                       FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <!-- Launch controls -->
            <StackPanel Spacing="8" IsVisible="{Binding IsClaudeInstalled}">
                <TextBlock Text="Additional instances to open:" FontSize="13"/>
                <NumericUpDown Value="{Binding SlotCount}"
                               Minimum="1" Maximum="10"
                               FormatString="0"
                               Width="120"
                               HorizontalAlignment="Left"/>
                <Button Content="Launch Claude"
                        Command="{Binding LaunchInstancesCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>

            <!-- Claude not found warning -->
            <StackPanel IsVisible="{Binding !IsClaudeInstalled}" Spacing="4">
                <TextBlock Text="&#x26A0; Claude Desktop is not installed."
                           Foreground="OrangeRed" FontSize="13"/>
                <TextBlock Text="Download Claude Desktop from claude.ai/download to use this launcher."
                           Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Settings row -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox Content="Launch on startup"
                          IsChecked="{Binding LaunchOnStartup}"
                          FontSize="12"
                          VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Refresh interval:" FontSize="12" VerticalAlignment="Center"/>
                    <NumericUpDown Value="{Binding RefreshIntervalSeconds}"
                                   Minimum="1" Maximum="60"
                                   FormatString="0"
                                   Width="130"
                                   VerticalAlignment="Center"/>
                    <TextBlock Text="s" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="[i]"
                               FontSize="11"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Cursor="Help"
                               ToolTip.Tip="How often the CPU, RAM and uptime stats refresh for each running Claude instance. Lower = more accurate but uses slightly more CPU. Recommended: 5s"/>
                </StackPanel>
            </StackPanel>

            <!-- Update available banner -->
            <Border Background="#1A4CAF25" CornerRadius="4" Padding="10,6"
                    IsVisible="{Binding UpdateAvailableMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="{Binding UpdateAvailableMessage}"
                           Foreground="#4CAF50" FontSize="11"
                           TextWrapping="Wrap"/>
            </Border>

            <Button Content="Open ComeOnOver"
                    Command="{Binding LaunchComeOnOverCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>

            <!-- Combined resource totals -->
            <Border BorderThickness="1" CornerRadius="4" Padding="10,8">
                <Grid ColumnDefinitions="*,*,*,Auto,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Running" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding RunningInstanceCount}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Total RAM" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalRamMb, StringFormat='{}{0} MB'}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Total CPU" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalCpuPercent, StringFormat='{}{0}%'}"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Grid.Column="3" Content="?"
                            Command="{Binding RefreshResourcesCommand}"
                            Padding="8,4" FontSize="13"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Refresh resource stats"/>
                    <Button Grid.Column="4" Content="Logs"
                            Command="{Binding OpenLogsFolderCommand}"
                            Padding="8,4" FontSize="11"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Open the diagnostic log folder in Explorer"/>
                </Grid>
            </Border>

            <!-- Per-instance resource list -->
            <ItemsControl ItemsSource="{Binding Instances}"
                          IsVisible="{Binding HasRunningInstances}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ClaudeInstanceViewModel">
                        <Border BorderThickness="0,0,0,1" Padding="0,8">
                            <Grid ColumnDefinitions="*,*,*,Auto,Auto">

                                <!-- Name + login status -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Border CornerRadius="3" Padding="5,2"
                                            ToolTip.Tip="{Binding LoginStatusTooltip}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding LoginStatusBackground}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding LoginStatusText}"
                                                   FontSize="9"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding LoginStatusForeground}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                    <TextBox Text="{Binding SlotName}"
                                             FontSize="12" FontWeight="SemiBold"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0,0,8,2"
                                             PlaceholderText="Name this slot..."
                                             VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- CPU -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="CPU" FontSize="9" Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CpuPercent, StringFormat='{}{0}%'}"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- RAM -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="RAM" FontSize="9" Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RamMb, StringFormat='{}{0} MB'}"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Uptime -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="Up" FontSize="9" Foreground="Gray"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding UptimeDisplay}"
                                               FontSize="12" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Kill button -->
                                <Button Grid.Column="4"
                                        Content="X"
                                        Command="{Binding KillCommand}"
                                        Foreground="#EF9A9A"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Padding="8,4"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        ToolTip.Tip="Close this Claude instance"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding AppVersion}"
                       Foreground="Gray" FontSize="10"
                       Opacity="0.5"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="Gray" FontSize="11"
                       HorizontalAlignment="Center"/>

        </StackPanel>
    </ScrollViewer>
</Window>







