<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ComeOnOverDesktopLauncher.ViewModels"
        x:Class="ComeOnOverDesktopLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ComeOnOver Desktop Launcher"
        Width="380" Height="320"
        MinWidth="320" MinHeight="280"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Margin="28" Spacing="16">

        <TextBlock Text="ComeOnOver Desktop Launcher"
                   FontSize="16" FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>

        <StackPanel Spacing="10" IsVisible="{Binding IsClaudeInstalled}">
            <TextBlock Text="Claude instances to open:" FontSize="13"/>
            <NumericUpDown Value="{Binding SlotCount}"
                           Minimum="1" Maximum="10"
                           FormatString="0"
                           Width="120"
                           HorizontalAlignment="Left"/>
            <Button Content="Launch Claude"
                    Command="{Binding LaunchInstancesCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="&#x26A0; Claude Desktop is not installed."
                   IsVisible="{Binding !IsClaudeInstalled}"
                   Foreground="OrangeRed"
                   FontSize="13"/>

        <Button Content="Open ComeOnOver"
                Command="{Binding LaunchComeOnOverCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"/>

        <!-- Running instance count -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="{Binding RunningInstanceCount, StringFormat='Running: {0}'}"
                       Foreground="Gray" FontSize="11"/>
            <Button Content="↻"
                    Command="{Binding RefreshInstanceCountCommand}"
                    Padding="4,0"
                    FontSize="11"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="Gray"
                   FontSize="11"
                   HorizontalAlignment="Center"/>

    </StackPanel>
</Window>
