<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ComeOnOverDesktopLauncher.Views.ConfirmDialog"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Title="Confirm"
        Background="#1E1E1E">

    <!--
        Keyboard behaviour (implemented in code-behind OnKeyDown):
          Enter  = invoke Confirm button (also wired via IsDefault="True")
          Esc    = invoke Cancel button
          Tab    = cycle between buttons (default Avalonia behaviour)

        x:Name (not plain Name) is required so the Avalonia compiled-XAML
        source generator emits accessor properties on the partial class;
        the service reads/writes these after construction via Apply.

        Grid rows are all Auto so SizeToContent="Height" can resolve to a
        concrete pixel height from the content (accent bar + text stack +
        buttons). A mix of Auto/*/Auto with SizeToContent creates a
        circular constraint and the window renders at zero height.
    -->

    <Grid RowDefinitions="Auto,Auto,Auto" Margin="20">

        <Border x:Name="SeverityAccent"
                Grid.Row="0"
                Height="4"
                CornerRadius="2"
                Margin="0,0,0,16"
                Background="#FFC107"/>

        <StackPanel Grid.Row="1" Spacing="10">
            <TextBlock x:Name="TitleText"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#F0F0F0"/>
            <TextBlock x:Name="MessageText"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="#C8C8C8"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,20,0,0">
            <Button x:Name="CancelButton"
                    MinWidth="90"
                    Click="OnCancelClick"/>
            <Button x:Name="ConfirmButton"
                    MinWidth="90"
                    IsDefault="True"
                    Click="OnConfirmClick"/>
        </StackPanel>

    </Grid>
</Window>